{
  "name": "scheduler-be",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"*.json\" \"*.md\" --log-level warn --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \"*.md\" --log-level warn --no-error-on-unmatched-pattern",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:named": "drizzle-kit generate --name",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:generate-schema": "better-auth generate -y --adapter drizzle --dialect postgresql --output ./src/db/auth-schema.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.10",
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth": "^1.6.10",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "pg": "^8.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
